# ============================================================
# bit-multi-brain-rag — environment configuration
# Copy to `.env` and fill real values. NEVER commit `.env`.
#
# Variable names MUST match pkg/config/config.go (these are what the
# binary reads). docker-compose.yml passes these through.
# ============================================================

# --- Server ---
# Dashboard HTTP listen address (Docker: keep default ":8081", host port mapped in compose).
HTTP_ADDR=:8081

# "dev" or "production". In production, validation enforces real API keys.
ENVIRONMENT=production

# --- Authentication (ADR-0003) ---
# Comma-separated list of valid API keys. At least 1 required in production.
# Generate strong random keys (min 32 chars), e.g.:
#   openssl rand -hex 32
# Each key grants GLOBAL access (all projects) in phase 1 (see ADR-0003).
DASHBOARD_API_KEYS=

# --- Embedding backend (ADR-0001) ---
# Default: internal llama.cpp service `embedder` (lihat docker-compose.yml).
# Ganti ke URL external kalau pakai voyage.bitsolution.my.id dll.
EMBEDDING_ENDPOINT=http://embedder:8080
EMBEDDING_MODEL=voyage-4-nano
EMBEDDING_DIM=1024
EMBEDDING_POOLING=mean
EMBEDDING_TIMEOUT_S=30

# API key untuk embedding server. Wajib di production kalau LLAMA_API_KEY
# di-set di embedder container (lihat docker-compose.yml).
EMBEDDING_API_KEY=

# Alias untuk embedder container env (llama-server auto-read LLAMA_API_KEY).
# Set sama dengan EMBEDDING_API_KEY di atas.
LLAMA_API_KEY=

# --- Vector store (Qdrant) ---
# Untuk Docker compose: pakai service name `qdrant` di network bit-rag-external
# (lihat docker-compose.qdrant.yml).
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# --- SQLite (project metadata store) ---
# Inside container, volume-mounted ke /app/data.
DB_PATH=/app/data/dashboard.db

# --- Active backend identifier (ADR-0001, ADR-0004) ---
# Collection naming: {project}_{domain}_{model}_{dim}_{backend}
ACTIVE_MODEL=voyage_nano_1024
ACTIVE_BACKEND=llama_q8

# --- MCP ---
# Disabled di dashboard service. MCP binary di-run terpisah via stdio.
MCP_ENABLED=false
